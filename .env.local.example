# PostHog Analytics — copie este arquivo para .env.local e preencha os valores
# .env.local é ignorado pelo git (nunca commite chaves reais)

# Chave do projeto PostHog (obrigatória para tracking)
NEXT_PUBLIC_POSTHOG_KEY=phc_SUBSTITUA_PELA_SUA_CHAVE

# Host do PostHog (padrão: EU cloud — escolha conforme sua região)
# EU:  https://eu.i.posthog.com
# US:  https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Taxa de amostragem de session replay (0 = desligado, 0.05 = 5%, 1 = 100%)
# Recomendado para LP: 0.05 a 0.10 para não impactar performance
NEXT_PUBLIC_POSTHOG_REPLAY_RATE=0
